{% set quote %}
  {% include '@organisms/quote/quote.twig' with {
    reverse: false,
    quote: "Being able to work with Penn State World Campus and find not only a degree program I was interested in, but knowing that I had that flexibility made it work perfectly for us.",
    attribution: "Carrie Tilley",
    byline: "Master of Engineering in Systems Engineering graduate",
  } only %}
{% endset %}

{% set callout %}
  {% include '@molecules/callout/callout.twig' with {
    background: 'light-grey',
    width: 'narrow',
    content: quote
  } only %}
{% endset %}

{% include '@molecules/background-container/background-container.twig' with {
  color: 'light-grey',
  sprite: 'shield',
  position: 'left',
  width: 'narrow',
  content: callout
} only %}
